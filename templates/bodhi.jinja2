menuentry "{{ title }}" --class {{ cls }} {
      search --label --set=root MP-DATA
      loadfont unicode      
      iso_path="/boot/iso/{{ filename }}"
      export iso_path
      loopback loop1 "$iso_path"
      root=(loop1)
      configfile /boot/grub/grub.cfg
      search --label --set=root MP-DATA
}
